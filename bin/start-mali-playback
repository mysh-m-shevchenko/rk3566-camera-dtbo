#!/bin/bash
#
# start-mali-playback - Load Mali GPU driver and start HDMI capture playback
#
# Copyright (c) 2024 MYSh LLC
# Author: Maksym Shevchenko <maksym.shevchenko@mysh.studio>
#
# Loads the Mali bifrost GPU driver, configures TC358743 HDMI input,
# and starts a GStreamer playback pipeline with GL-accelerated rendering.
#
# Tested on: Radxa Zero 3W (RK3566, Mali-G52)
#
# Usage:
#   start-mali-playback [edid-file]
#
# Arguments:
#   edid-file   Path to EDID file (default: /usr/share/rk3566-camera-dtbo/edid/1080p30edid)
#
# Prerequisites:
#   - TC358743 overlay enabled
#   - Mali bifrost_kbase kernel module available
#   - GStreamer with GL plugins installed
#   - media-ctl and v4l2-ctl available
#

set -e

EDID_DIR="/usr/share/rk3566-camera-dtbo/edid"
EDID_FILE="${1:-${EDID_DIR}/1080p30edid}"
MEDIA_DEV="/dev/media0"
VIDEO_DEV="/dev/video0"

# Find TC358743 subdev via media graph
SUBDEV=$(media-ctl -d "$MEDIA_DEV" -e "m00_b_tc35874x 2-000f" 2>/dev/null)
if [ -z "$SUBDEV" ]; then
    echo "ERROR: TC358743 device not found in media graph" >&2
    exit 1
fi

# Load Mali bifrost GPU driver
if ! lsmod | grep -q bifrost_kbase; then
    sudo modprobe bifrost_kbase
    sleep 1
fi

# Set EDID on HDMI input
sudo v4l2-ctl --set-edid=file="$EDID_FILE" -d "$SUBDEV"
sleep 1

# Detect and set DV timings from incoming signal
sudo v4l2-ctl -d "$SUBDEV" --set-dv-bt-timings query

# Update media pipeline format to match
media-ctl -d "$MEDIA_DEV" --set-v4l2 "\"m00_b_tc35874x 2-000f\":0[fmt:UYVY8_2X8/1920x1080]"

# Run GStreamer pipeline with GL-accelerated sink
GST_GL_API=gles2 GST_GL_PLATFORM=egl \
    gst-launch-1.0 v4l2src device="$VIDEO_DEV" \
    ! video/x-raw,width=1920,height=1080,format=NV12 \
    ! glimagesink sync=no
